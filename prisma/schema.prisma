// MedSafe Prisma schema — Supabase (hosted Postgres).
// Seeded from DDInter 2.0 (see /prisma/seed.ts and /prisma/data/*.csv).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Severity {
  Minor
  Moderate
  Major
}

model Drug {
  id    Int     @id @default(autoincrement())
  rxcui String?
  name  String  @unique
}

model Interaction {
  id          Int      @id @default(autoincrement())
  drugAName   String
  drugBName   String
  severity    Severity
  mechanism   String?
  description String?

  @@index([drugAName, drugBName])
}
